{
  "openapi": "3.0.0",
  "info": {
    "title": "Restful Booker API",
    "version": "1.0.0",
    "description": "Sample API for practicing CRUD operations"
  },
  "servers": [
    {
      "url": "https://restful-booker.herokuapp.com"
    }
  ],
  "paths": {
    "/ping": {
      "get": {
        "summary": "Health Check",
        "responses": {
          "201": {
            "description": "API is up"
          }
        }
      }
    },

    "/auth": {
      "post": {
        "summary": "Create Auth Token",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token created"
          }
        }
      }
    },

    "/booking": {
      "get": {
        "summary": "Get all bookings",
        "responses": {
          "200": {
            "description": "List of booking IDs"
          }
        }
      },

      "post": {
        "summary": "Create booking",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Booking"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Booking created"
          }
        }
      }
    },

    "/booking/{id}": {
      "get": {
        "summary": "Get booking by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Booking details"
          }
        }
      },

      "put": {
        "summary": "Update booking",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Booking updated"
          }
        }
      },

      "patch": {
        "summary": "Partial update booking",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Booking partially updated"
          }
        }
      },

      "delete": {
        "summary": "Delete booking",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Booking deleted"
          }
        }
      }
    }
  },

  "components": {
    "schemas": {
      "Booking": {
        "type": "object",
        "properties": {
          "firstname": {
            "type": "string"
          },
          "lastname": {
            "type": "string"
          },
          "totalprice": {
            "type": "integer"
          },
          "depositpaid": {
            "type": "boolean"
          },
          "bookingdates": {
            "type": "object",
            "properties": {
              "checkin": {
                "type": "string",
                "format": "date"
              },
              "checkout": {
                "type": "string",
                "format": "date"
              }
            }
          },
          "additionalneeds": {
            "type": "string"
          }
        }
      }
    }
  }
}